# MapTiler API key
# Usata per layer satellite/base map opzionali
VITE_MAPTILER_KEY=

# Thunderforest API key
# Usata per layer outdoor/agricoli opzionali
VITE_THUNDERFOREST_KEY=

# Copernicus Data Space
VITE_COPERNICUS_BASE_URL=https://catalogue.dataspace.copernicus.eu
VITE_COPERNICUS_STATS_ENDPOINT=/api/copernicus-statistics
VITE_COPERNICUS_USERNAME=
VITE_COPERNICUS_PASSWORD=
VITE_COPERNICUS_CLIENT_ID=cdse-public
VITE_COPERNICUS_CLIENT_SECRET=
VITE_COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
VITE_COPERNICUS_STATS_URL=https://sh.dataspace.copernicus.eu/api/v1/statistics
VITE_COPERNICUS_COLLECTION=sentinel-2-l2a
VITE_COPERNICUS_LOOKBACK_DAYS=30
VITE_COPERNICUS_MAX_CLOUD_COVER=20

# Open Meteo
VITE_OPEN_METEO_BASE_URL=https://api.open-meteo.com

# Backend GIS
VITE_GIS_API_URL=http://localhost:5000

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
